#! /usr/bin/env nix-shell
#! nix-shell --show-trace ./updater-emacs.nix -i bash

SCRIPT_DIR="$( cd "$(dirname "$0")" ; pwd -P )"

exec emacs --fg-daemon=updater --quick -l "$SCRIPT_DIR/update-elpa.el" \
    -f "run-updater" "elpa" "https://elpa.gnu.org/packages/" "reciepes-archive-elpa.json" \
    --kill \
    "$@"
